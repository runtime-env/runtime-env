{
  "name": "@runtime-env/hmr",
  "version": "0.1.0",
  "description": "Build once, deploy anywhere. Startup/runtime environment variable solution for JavaScript.",
  "license": "MIT",
  "author": "Ernest",
  "keywords": [
    "twelve-factor",
    "dotenv",
    "import-meta-env",
    "json-schema"
  ],
  "files": [
    "bin"
  ],
  "scripts": {
    "build": "rimraf bin && tsc && pnpm build-hmr",
    "build-hmr": "esbuild src/index.ts --bundle --platform=node --target=node14 --outfile=dist/index.js",
    "pack": "rm -f *.tgz && pnpm pack && node ../../scripts/rename-tgz.js",
    "release": "standard-version --skip.tag -t hmr --preset=conventionalcommits --releaseCommitMessageFormat 'chore(release): @runtime-env/hmr@{{currentTag}}' --path .",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runtime-env/runtime-env.git",
    "directory": "packages/hmr"
  },
  "bugs": {
    "url": "https://github.com/runtime-env/runtime-env/issues"
  },
  "homepage": "https://github.com/runtime-env/runtime-env#readme",
  "devDependencies": {
    "@types/chalk": "^2.2.0",
    "@types/glob": "8.1.0",
    "@types/lodash": "^4.14.202",
    "@types/serialize-javascript": "5.0.3",
    "dotenv": "^16.3.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "dotenv": "*"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "chalk": "^5.3.0",
    "commander": "11.1.0",
    "cosmiconfig": "^8.3.6",
    "json-schema-to-typescript": "^13.1.1",
    "lodash": "^4.17.21",
    "picocolors": "1.0.0",
    "serialize-javascript": "6.0.1",
    "zod": "^3.22.4"
  }
}
